# ── LLM (OpenAI 兼容, 默认 DeepSeek) ─────────────────────────────────
MEMOCORTEX_LLM_API_KEY=sk-your-deepseek-key
MEMOCORTEX_LLM_API_BASE=https://api.deepseek.com/v1
MEMOCORTEX_LLM_MODEL=deepseek-chat

# ── Embedding (本地 HuggingFace) ──────────────────────────────────────
MEMOCORTEX_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── 存储路径 ──────────────────────────────────────────────────────────
MEMOCORTEX_DATA_DIR=./data
# 内部派生:
#   chroma_dir   = $DATA_DIR/chroma
#   sqlite_path  = $DATA_DIR/memocortex.db
#   graph_dir    = $DATA_DIR/graph
#   cold_dir     = $DATA_DIR/cold

# ── MCP 服务端口 ────────────────────────────────────────────────────
MEMOCORTEX_MCP_PORT=8766

# ── 记忆参数 ──────────────────────────────────────────────────────────
MEMOCORTEX_WORKING_CAPACITY=20            # 单 session 最多保留多少条
MEMOCORTEX_EPISODIC_TTL_DAYS=30           # episodic 超过此天数考虑降级为 semantic
MEMOCORTEX_DEFAULT_TOP_K=8                # search 默认返回条数

# ── 召回权重 (4 信号融合, 总和建议 = 1.0) ─────────────────────────────
MEMOCORTEX_RECALL_W_VECTOR=0.40
MEMOCORTEX_RECALL_W_TEMPORAL=0.20
MEMOCORTEX_RECALL_W_KEYWORD=0.20
MEMOCORTEX_RECALL_W_IMPORTANCE=0.20
MEMOCORTEX_TEMPORAL_TAU_DAYS=30           # 时间衰减时间常数

# ── 反思 Worker 间隔 (秒, MVP 调短便于演示) ───────────────────────────
MEMOCORTEX_REFLECT_DISTILL_INTERVAL_SEC=3600
MEMOCORTEX_REFLECT_MERGE_INTERVAL_SEC=7200
MEMOCORTEX_REFLECT_DECAY_INTERVAL_SEC=3600
MEMOCORTEX_REFLECT_PROFILE_INTERVAL_SEC=86400
MEMOCORTEX_PATTERN_MINE_INTERVAL_SEC=1800      # Pattern Miner 定期扫描间隔

# ── 调试 ──────────────────────────────────────────────────────────────
MEMOCORTEX_DEBUG=true
MEMOCORTEX_LOG_LEVEL=INFO
